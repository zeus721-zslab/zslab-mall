# ===========================================
# zslab-mall 환경 변수 템플릿
# 사용법: 이 파일을 .env로 복사 후 실제 값 입력
# .env는 .gitignore 처리됨 (절대 커밋 금지)
# ===========================================

# ----- Spring Profile -----
SPRING_PROFILES_ACTIVE=local

# ----- Dockerfile 선택 (Dockerfile.dev | Dockerfile) -----
BACKEND_DOCKERFILE=Dockerfile.dev

# ----- Database (MariaDB) -----
# DB_HOST·DB_PORT는 docker-compose.mall.yml에서 zslab_mariadb·3306으로 박제 (로컬·운영 동일)
DB_NAME=zslab_mall
DB_USERNAME=zslab_mall
DB_PASSWORD=

# ----- Redis -----
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=

# ----- JWT -----
JWT_SECRET=
JWT_ACCESS_EXPIRATION=3600
JWT_REFRESH_EXPIRATION=604800

# ----- 최초 SUPER_ADMIN 부트스트랩 (Track 38) -----
# SUPER_ADMIN 회원이 하나도 없을 때에만 최초 1회 소비돼 SUPER_ADMIN 계정을 생성한다.
# 이미 SUPER_ADMIN 존재 시 미참조(무작업). 신선한 DB 최초 기동 시 두 값 필수(비어 있으면 기동 실패·Fail Fast).
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=

# ----- Domain / CORS -----
APP_DOMAIN=zslab-mall.duckdns.org
CORS_ALLOWED_ORIGINS=https://zslab-mall.duckdns.org

# ----- Frontend (Nuxt) -----
# NUXT_PUBLIC_API_BASE: 브라우저->API 베이스 (동일 Origin 상대경로). gateway path split 도입 후 확정.
# API_INTERNAL_BASE: SSR->backend 직결 (gateway_net 내부·별칭 mall-backend 사용).
#   Tomcat 엄격 Host 검증이 언더스코어 호스트명(zslab_mall_backend) 거부(커넥터 400) → 언더스코어 없는 별칭으로 회피.
NUXT_PUBLIC_API_BASE=/api
API_INTERNAL_BASE=http://mall-backend:8080
# 데모 로그인 버튼용 공개 자격증명(저권한 BUYER). public 노출 전제라 NUXT_PUBLIC_ 접두사 사용.
NUXT_PUBLIC_DEMO_EMAIL=
NUXT_PUBLIC_DEMO_PASSWORD=

# ----- File Upload -----
UPLOAD_PATH=/app/uploads
UPLOAD_MAX_SIZE=10485760

# ----- Logging -----
LOG_LEVEL=INFO
LOG_PATH=/app/logs

# ----- Elasticsearch (log 수집) -----
# 무인증 HTTP. 컨테이너명·포트 기본값만 (실값 필요 시 서버 .env 에서 재정의)
ES_HOST=zslab_elasticsearch
ES_PORT=9200

# ===========================================
# 아래는 1차 범위 미사용 (자리 확보)
# ===========================================

# ----- PG / 결제 -----
PG_PROVIDER=
PG_API_KEY=
PG_SECRET_KEY=

# ----- Email (SMTP) -----
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# ----- SMS -----
SMS_API_KEY=