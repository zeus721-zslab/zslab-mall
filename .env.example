# ===========================================
# zslab-mall 환경 변수 템플릿
# 사용법: 이 파일을 .env로 복사 후 실제 값 입력
# .env는 .gitignore 처리됨 (절대 커밋 금지)
# ===========================================

# ----- Spring Profile -----
SPRING_PROFILES_ACTIVE=local

# ----- Dockerfile 선택 (Dockerfile.dev | Dockerfile) -----
BACKEND_DOCKERFILE=Dockerfile.dev

# ----- Database (MariaDB) -----
# DB_HOST·DB_PORT는 docker-compose.mall.yml에서 zslab_mariadb·3306으로 박제 (로컬·운영 동일)
DB_NAME=zslab_mall
DB_USERNAME=zslab_mall
DB_PASSWORD=

# ----- Redis -----
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=

# ----- JWT -----
JWT_SECRET=
JWT_ACCESS_EXPIRATION=3600
JWT_REFRESH_EXPIRATION=604800

# ----- Domain / CORS -----
APP_DOMAIN=zslab-mall.duckdns.org
CORS_ALLOWED_ORIGINS=https://zslab-mall.duckdns.org

# ----- File Upload -----
UPLOAD_PATH=/app/uploads
UPLOAD_MAX_SIZE=10485760

# ----- Logging -----
LOG_LEVEL=INFO
LOG_PATH=/app/logs

# ===========================================
# 아래는 1차 범위 미사용 (자리 확보)
# ===========================================

# ----- PG / 결제 -----
PG_PROVIDER=
PG_API_KEY=
PG_SECRET_KEY=

# ----- Email (SMTP) -----
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# ----- SMS -----
SMS_API_KEY=