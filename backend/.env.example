# Database
DB_URL=jdbc:mariadb://localhost:3306/zslab_mall?useUnicode=true&characterEncoding=utf8&serverTimezone=UTC
DB_USERNAME=zslab_mall
DB_PASSWORD=

# Profile (local | prod)
SPRING_PROFILES_ACTIVE=local

# JWT (후속 트랙 추가)
# JWT_SECRET=

# 최초 SUPER_ADMIN 부트스트랩 (Track 38) — SUPER_ADMIN 부재 시에만 최초 1회 소비돼 계정 생성. 이미 존재 시 무작업.
# 신선한 DB 최초 기동 시 필수(비어 있으면 기동 실패·Fail Fast). 값은 실제 운영 시 안전한 값으로 교체.
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=

